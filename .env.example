# Copy this file to .env and fill in your own values.
# .env must NOT be committed to git (it's already in .gitignore) — it holds the secret token.

# Bot token from the Discord Developer Portal (Application -> Bot -> Reset Token)
DISCORD_TOKEN=paste_your_bot_token_here

# --- Optional settings (can be removed — defaults will be used) ---

# Default player volume, 0.0 - 2.0
DEFAULT_VOLUME=0.5

# Maximum tracks in the queue (0 = unlimited)
MAX_QUEUE_SIZE=0

# Seconds of inactivity after which the bot leaves the voice channel on its own
INACTIVITY_TIMEOUT=300

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# --- Spotify support (optional — needed only if you want /play to accept open.spotify.com links) ---
# Get these for free at https://developer.spotify.com/dashboard -> Create app
# (no special access needed, the default Web API scope is enough)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Max tracks to pull from a single Spotify album/playlist link
SPOTIFY_MAX_TRACKS=25
